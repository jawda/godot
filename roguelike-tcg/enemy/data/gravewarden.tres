[resource]
script = ExtResource("1")
enemy_name = "The Gravewarden"
tier = 3
description = "It was built to guard something — no one living remembers what. Whatever it protected is long gone. The Gravewarden remains, and it has grown very tired of intruders."
tags = Array[String](["undead"])
max_health = 250
base_attack = 15
base_block = 10
actions = Array[ExtResource("2")]([SubResource("Action_p1_slam"), SubResource("Action_p1_harden"), SubResource("Action_p1_crush"), SubResource("Action_p1_summon")])
phases = Array[ExtResource("3")]([SubResource("Phase_cracked"), SubResource("Phase_fury")])
