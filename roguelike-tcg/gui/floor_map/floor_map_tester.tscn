[gd_scene format=3]

[ext_resource type="Script" path="res://gui/floor_map/floor_map_tester.gd" id="1_ft"]
[ext_resource type="PackedScene" path="res://gui/floor_map/floor_map.tscn" id="2_fm"]

[sub_resource type="StyleBoxFlat" id="PanelStyle"]
bg_color = Color(0.08, 0.07, 0.11, 0.90)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
