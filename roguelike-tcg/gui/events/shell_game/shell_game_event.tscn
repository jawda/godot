theme_override_font_sizes/font_size = 13
text = "A weathered barkeep slides three worn cups across the counter. Something clinks softly beneath one of them.

\"Card shark, are you? How about a simple game — you pick a card, I hide it, give the cups a shuffle. If you find it and I'll get you a second copy.\"

He shrugs. \"Lose and it's mine. What do you say?\""
autowrap_mode = 3

